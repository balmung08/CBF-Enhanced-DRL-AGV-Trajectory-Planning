          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </ray>
        <plugin name="lidar_rear_right_ros" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/agv_4wis</namespace>
