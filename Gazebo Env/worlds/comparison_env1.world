<?xml version="1.0"?>
<sdf version="1.6">
  <world name="comparison_env1">
    <gui>
      <plugin name="agv_hide_collisions_gui" filename="libagv_hide_collisions_gui.so"/>
      <camera name="top_down_camera">
        <pose>20 10 45 0 1.5707963267948966 0</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>
    <physics name="ode" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <light name="sun" type="directional">
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.85 0.85 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.16 0.18 0.20 1</ambient>
            <diffuse>0.28 0.31 0.34 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Rectangles are copied from Env1/Optimal_Traj.py. -->
    <model name="south_wall">
      <static>true</static><pose>20 -1 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>40 2 3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>40 2 3</size></box></geometry>
          <material><ambient>0.22 0.25 0.30 1</ambient><diffuse>0.38 0.43 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="north_left_wall">
      <static>true</static><pose>6.5 9 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>17 2 3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>17 2 3</size></box></geometry>
          <material><ambient>0.22 0.25 0.30 1</ambient><diffuse>0.38 0.43 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="right_vertical_wall">
      <static>true</static><pose>24 16.5 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>2 17 3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2 17 3</size></box></geometry>
          <material><ambient>0.22 0.25 0.30 1</ambient><diffuse>0.38 0.43 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="left_vertical_wall">
      <static>true</static><pose>14 17.5 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>2 15 3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2 15 3</size></box></geometry>
          <material><ambient>0.22 0.25 0.30 1</ambient><diffuse>0.38 0.43 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="north_right_wall">
      <static>true</static><pose>32.5 9 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>15 2 3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>15 2 3</size></box></geometry>
          <material><ambient>0.22 0.25 0.30 1</ambient><diffuse>0.38 0.43 0.50 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="circle_obstacle_1">
      <static>true</static><pose>20.5 13 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.45</radius><length>3</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.45</radius><length>3</length></cylinder></geometry>
          <material><ambient>0.45 0.16 0.04 1</ambient><diffuse>0.90 0.34 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="circle_obstacle_2">
      <static>true</static><pose>13 5.5 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.75</radius><length>3</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.75</radius><length>3</length></cylinder></geometry>
          <material><ambient>0.45 0.16 0.04 1</ambient><diffuse>0.90 0.34 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="circle_obstacle_3">
      <static>true</static><pose>17 8 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><cylinder><radius>0.75</radius><length>3</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.75</radius><length>3</length></cylinder></geometry>
          <material><ambient>0.45 0.16 0.04 1</ambient><diffuse>0.90 0.34 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <include>
      <uri>model://agv_robot</uri>
      <pose>5.5 4.5 0 0 0 0.5235987755982988</pose>
    </include>
  </world>
</sdf>
